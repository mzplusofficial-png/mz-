{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the MZ+ system.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fcmToken": { "type": "string" },
        "lastFcmSync": { "type": "string", "format": "date-time" },
        "userLevel": { "type": "string", "enum": ["standard", "niveau_mz_plus"] },
        "isAdmin": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "fullName", "email"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "A message in a private chat or AI chat.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "isAi": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "text", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System notification for a user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "success", "warning", "premium"] },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Public and private user profiles."
    },
    "/admins/{adminId}": {
      "schema": "object",
      "description": "Admin list for security rules."
    },
    "/chats/{chatId}": {
      "schema": "object",
      "description": "Chat metadata."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages within a specific chat."
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System-wide and targeted notifications."
    }
  }
}
